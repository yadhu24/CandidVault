# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database
DATABASE_URL=

# Cloudflare R2
# Bucket MUST be private (no public access / no public r2.dev domain for originals).
# The R2 API token needs object read/write on this bucket. Configure bucket CORS to
# allow PUT from NEXT_PUBLIC_APP_URL (https://candidvault.org in prod; see README).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Uploads — server-only secret used to sign short-lived upload tickets.
# Generate a long random value, e.g. `openssl rand -base64 48`.
UPLOAD_SIGNING_SECRET=

# App — public base URL for all absolute links: QR code targets, guest share
# links, and OG/canonical metadata. No trailing slash. MUST be set in the host
# for production. If unset, the app falls back to the production domain.
#   Production (set this in the host):  https://candidvault.org
#   Local dev:                          http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
